@startuml
title 图4-1 系统硬件连接总图

left to right direction
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Microsoft YaHei
skinparam linetype ortho
skinparam ArrowColor #666666
skinparam rectangle {
  BackgroundColor white
  BorderColor #888888
  FontColor #222222
  RoundCorner 4
}

rectangle "土壤湿度传感器" as S1
rectangle "温湿度传感器" as S2
rectangle "光照传感器" as S3
rectangle "STM32控制节点" as MCU
rectangle "树莓派边缘端" as PI
rectangle "摄像头" as CAM
rectangle "继电器模块" as RELAY
rectangle "水泵" as PUMP
rectangle "灯带" as LED

S1 --> MCU
S2 --> MCU
S3 --> MCU

MCU <--> PI
CAM --> PI

MCU --> RELAY
RELAY --> PUMP
RELAY --> LED

@enduml