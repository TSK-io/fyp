@startuml
title 图5-2 设备端主程序流程图

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Microsoft YaHei
skinparam ArrowColor #666666
skinparam activity {
  BackgroundColor white
  BorderColor #888888
  FontColor #222222
}

start
:系统上电;
:初始化硬件资源;
:初始化传感器;
:初始化显示模块;
:初始化串口通信;

while (是否持续运行) is (是)
  :轮询设备状态;
  :采集环境数据;
  :显示当前信息;
  if (收到控制命令?) then (是)
    :解析命令;
    :执行相应控制;
  else (否)
  endif
endwhile (否)

stop
@enduml