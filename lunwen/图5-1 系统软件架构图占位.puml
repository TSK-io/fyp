@startuml
title 图5-1 系统软件架构图

top to bottom direction
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Microsoft YaHei
skinparam linetype ortho
skinparam ArrowColor #666666
skinparam rectangle {
  BackgroundColor white
  BorderColor #888888
  FontColor #222222
  RoundCorner 4
}

rectangle "固件层\nSTM32数据采集与设备控制" as FIRMWARE
rectangle "边缘服务层\n串口通信、数据处理、自动控制、Flask服务" as EDGE
rectangle "数据库层\nSQLite数据存储" as DB
rectangle "前端展示层\nWeb页面、状态监控、历史查询、远程控制" as FRONT

FIRMWARE --> EDGE
EDGE --> DB
FRONT --> EDGE

@enduml